{
  "id": "inventory-excel",
  "name": "庫存 Excel 月結整理",
  "status": "official",
  "builtin": true,
  "description": "登入 webmail 抓指定日期附檔，篩選日期區間並 highlight，另存新檔",
  "longDescription": "這是一個範例 workflow，示範怎麼把一件事拆成好幾個節點串起來：\n1. 開始(可帶報表日期)\n2. 登入公司 webmail(圖形驗證碼由 AI 自動辨識)\n3. 用日期+報表名稱精準找到那封信\n4. 下載 Excel 附件\n5. 篩選指定分頁的日期區間、整列 highlight、另存新檔\n\n你可以「複製」這個範例改成自己要的(例如抓不同的信、篩不同區間)，或點任一節點用白話叫 AI 微調。webmail 帳密在設定頁填。",
  "defaultModel": "minimax-m3",
  "requiresSecrets": [
    {
      "key": "webmailUrl",
      "label": "Webmail 網址",
      "type": "text"
    },
    {
      "key": "webmailAccount",
      "label": "Webmail 帳號",
      "type": "text"
    },
    {
      "key": "webmailPassword",
      "label": "Webmail 密碼",
      "type": "password"
    }
  ],
  "triggerParams": [
    {
      "key": "periodUnit",
      "label": "結算期間單位",
      "type": "select",
      "options": [
        "month=每月",
        "bimonth=每兩個月",
        "quarter=每季",
        "half=每半年",
        "year=每年"
      ],
      "default": "month",
      "help": "要結算多長的期間"
    },
    {
      "key": "periodWhich",
      "label": "哪一個期間",
      "type": "select",
      "options": [
        "last=上一個(結算剛過完的)",
        "this=這一個(目前進行中)"
      ],
      "default": "last",
      "help": "排程時通常用「上一個」，跑完剛結束的期間"
    },
    {
      "key": "filterStart",
      "label": "篩選開始(自動)",
      "type": "date-or-token",
      "default": "{{period.start}}",
      "derived": true
    },
    {
      "key": "filterEnd",
      "label": "篩選結束(自動)",
      "type": "date-or-token",
      "default": "{{period.end}}",
      "derived": true
    },
    {
      "key": "targetDate",
      "label": "報表日期(自動)",
      "type": "date-or-token",
      "default": "{{period.reportDate}}",
      "derived": true,
      "help": "資料算前一天，所以抓期間結束隔天那封信"
    },
    {
      "key": "outputName",
      "label": "輸出檔名(自動)",
      "type": "text",
      "default": "庫存報表{{period.label}}",
      "derived": true
    }
  ],
  "nodes": [
    {
      "id": "n1",
      "type": "trigger",
      "label": "開始",
      "config": {},
      "position": {
        "x": 80,
        "y": 200
      }
    },
    {
      "id": "n2",
      "type": "browser-login",
      "label": "登入 webmail",
      "config": {
        "url": "{{webmailUrl}}"
      },
      "position": {
        "x": 340,
        "y": 200
      }
    },
    {
      "id": "n3",
      "type": "find-email",
      "label": "找信件",
      "config": {
        "date": "{{targetDate}}",
        "subjectContains": "每日庫存報表"
      },
      "position": {
        "x": 600,
        "y": 200
      }
    },
    {
      "id": "n4",
      "type": "download-attachment",
      "label": "下載附件",
      "config": {
        "nameContains": "每日庫存報表"
      },
      "position": {
        "x": 860,
        "y": 200
      }
    },
    {
      "id": "n5",
      "type": "excel-process",
      "label": "篩選+highlight+存檔",
      "config": {
        "inputPath": "{{attachmentPath}}",
        "sheet": "工作表1",
        "filterStart": "{{filterStart}}",
        "filterEnd": "{{filterEnd}}",
        "highlight": "FFC000",
        "outputName": "{{outputName}}",
        "highlightColumn": "待補貨"
      },
      "position": {
        "x": 1120,
        "y": 200
      }
    }
  ],
  "edges": [
    {
      "from": "n1",
      "to": "n2"
    },
    {
      "from": "n2",
      "to": "n3"
    },
    {
      "from": "n3",
      "to": "n4"
    },
    {
      "from": "n4",
      "to": "n5"
    }
  ]
}
