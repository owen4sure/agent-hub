{
  "id": "inbox-summary",
  "category": "檔案自動化",
  "icon": "📁",
  "name": "丟進資料夾就自動摘要",
  "description": "把 PDF/Word/txt 丟進監聽資料夾 → 自動抽文字 → AI 摘要三重點 → 存檔+桌面通知。",
  "nodes": [
    {
      "id": "t",
      "type": "trigger",
      "label": "監聽資料夾",
      "config": {
        "watchPath": ""
      },
      "position": {
        "x": 0,
        "y": 120
      }
    },
    {
      "id": "read",
      "type": "read-file",
      "label": "讀檔案內容",
      "config": {
        "path": "{{filePath}}",
        "maxChars": "20000"
      },
      "position": {
        "x": 260,
        "y": 120
      }
    },
    {
      "id": "sum",
      "type": "llm-decide",
      "label": "AI 摘要三重點",
      "config": {
        "prompt": "把這份文件摘要成三個重點(繁中,每點一行):\n{{fileText}}",
        "outputKey": "summary"
      },
      "position": {
        "x": 520,
        "y": 120
      }
    },
    {
      "id": "save",
      "type": "write-file",
      "label": "存摘要檔",
      "config": {
        "fileName": "摘要_{{fileName}}.txt",
        "content": "{{summary}}"
      },
      "position": {
        "x": 780,
        "y": 120
      }
    },
    {
      "id": "ding",
      "type": "desktop-notify",
      "label": "通知我",
      "config": {
        "title": "摘要完成",
        "message": "{{fileName}} 的三個重點已存檔"
      },
      "position": {
        "x": 1040,
        "y": 120
      }
    }
  ],
  "edges": [
    {
      "from": "t",
      "to": "read"
    },
    {
      "from": "read",
      "to": "sum"
    },
    {
      "from": "sum",
      "to": "save"
    },
    {
      "from": "save",
      "to": "ding"
    }
  ]
}