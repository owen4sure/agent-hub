      "label": "欄位二",
      "type": "text",
      "default": ""
    }
  ],
  "nodes": [
    {
      "id": "t",
      "type": "trigger",
      "label": "開始(Webhook/表單)",
      "config": {},
      "position": {
        "x": 0,
        "y": 120
      }
    },
    {
      "id": "row",
      "type": "google-sheet-append",
      "label": "寫進試算表",
      "config": {
        "cells": "{{today}}, {{field1}}, {{field2}}",
